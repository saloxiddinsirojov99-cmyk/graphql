generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  age   Int
  posts Post[]
}

model Post {
  id       Int    @id @default(autoincrement())
  title    String
  body     String
  filePath String?
  userId   Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
